msgstr "हटाने में त्रुटि: %s"

msgid "Error reading log: %s"
msgstr "लॉग पढ़ने में त्रुटि: %s"

msgid "Execution error"
msgstr "निष्पादन त्रुटि"

msgid "Exit"
msgstr "बाहर निकलना"

msgid "Failed to start command.\n"
msgstr "आदेश प्रारंभ करने में विफल.\n"

msgid "Full Log"
msgstr "पूर्ण लॉग"

msgid "Hide Logs"
msgstr "लॉग छिपाएँ"

msgid "Info"
msgstr "जानकारी"

msgid "Log files found: %d | Press Info for show"
msgstr "लॉग फ़ाइलें मिलीं: %d | दिखाने के लिए जानकारी दबाएँ"

msgid "Manager"
msgstr "प्रबंधक"

msgid "No command selected"
msgstr "कोई आदेश चयनित नहीं"

msgid "No output to save"
msgstr "सहेजने के लिए कोई आउटपुट नहीं"

msgid "No specific error trace found in log"
msgstr "लॉग में कोई विशिष्ट त्रुटि चिह्न नहीं मिला"

msgid "Only predefined commands can be disabled/enabled"
msgstr "केवल पूर्वनिर्धारित कमांड को ही अक्षम/सक्षम किया जा सकता है"

msgid "Output cleared.\n"
msgstr "आउटपुट साफ़ हो गया.\n"

msgid "Press Manager to manage custom commands"
msgstr "कस्टम कमांड प्रबंधित करने के लिए मैनेजर दबाएँ"

msgid "Ready"
msgstr "तैयार"

msgid "Run"
msgstr "दौड़ना"

msgid "Run telnet/shell commands on Enigma2"
msgstr "Enigma2 पर टेलनेट/शेल कमांड चलाएँ"

msgid "Save"
msgstr "बचाना"

msgid "Save error: %s"
msgstr "त्रुटि सहेजें: %s"

msgid "Saved to %s"
msgstr "%s में सहेजा गया"

msgid "Select a debug command and press Run"
msgstr "डिबग कमांड चुनें और रन दबाएँ"

msgid "Show Logs"
msgstr "लॉग दिखाएँ"

msgid "Toggle Disable"
msgstr "अक्षम करें टॉगल करें"

msgid "Total: %d commands (Predefined: %d, Custom: %d, Disabled: %d)"
msgstr "कुल: %d कमांड (पूर्वनिर्धारित: %d, कस्टम: %d, अक्षम: %d)"
