msgid "Add Custom"
msgstr "कस्टम जोड़ें"

msgid "Back"
msgstr "पीछे"

msgid "Clear"
msgstr "स्पष्ट"

msgid "Close"
msgstr "बंद करना"

msgid "Command Center - Telnet/Shell Plugin v.%s - by Lululla."
msgstr "कमांड सेंटर - टेलनेट/शेल प्लगइन v.%s - लुलुल्ला द्वारा।"

msgid "Command Center v.%s"
msgstr "कमांड सेंटर v.%s"

msgid "Command finished (code %d)"
msgstr "आदेश समाप्त (कोड %d)"

msgid "Confirm Debug Command"
msgstr "डिबग कमांड की पुष्टि करें"

msgid "Debug Log: %s"
msgstr "दोषमार्जन लॉग"

msgid "Delete Log"
msgstr "लॉग हटाएँ"

msgid "Delete/Disable"
msgstr "हटाएँ/अक्षम करें"

msgid "Deleted: %s"
msgstr "हटाया गया: %s"

msgid "Edit"
msgstr "संपादन करना"

msgid "Edit command"
msgstr "आदेश संपादित करें"

msgid "Edit command (original: %s)"
msgstr "आदेश संपादित करें (मूल: %s)"

msgid "Edit description"
msgstr "संपादित करें] वर्णन"

msgid "Enter command"
msgstr "आदेश दर्ज करें"

msgid "Enter description"
msgstr "विवरण दर्ज करें"

msgid "Error Only"
msgstr "केवल त्रुटि"

