msgstr "ပိတ်လိုက်"

msgid "Command Center - Telnet/Shell Plugin v.%s - by Lululla."
msgstr "ကွပ်ကဲမှုစင်တာ - Telnet/Shell Plugin v.%s - Lululla မှ။"

