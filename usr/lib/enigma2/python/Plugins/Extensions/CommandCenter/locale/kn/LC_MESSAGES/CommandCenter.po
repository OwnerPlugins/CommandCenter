msgid "Add Custom"
msgstr "ಕಸ್ಟಮ್ ಸೇರಿಸಿ"

msgid "Back"
msgstr "ಹಿಂದೆ"

msgid "Clear"
msgstr "ತೆರವುಗೊಳಿಸಿ"

msgid "Close"
msgstr "ಮುಚ್ಚಿ"

msgid "Command Center - Telnet/Shell Plugin v.%s - by Lululla."
msgstr "ಕಮಾಂಡ್ ಸೆಂಟರ್ - ಟೆಲ್ನೆಟ್/ಶೆಲ್ ಪ್ಲಗಿನ್ v.%s - ಲುಲುಲ್ಲಾ ಅವರಿಂದ."

msgid "Command Center v.%s"
msgstr "ಕಮಾಂಡ್ ಸೆಂಟರ್ v.%s"

msgid "Command finished (code %d)"
msgstr "ಆದೇಶ ಮುಗಿದಿದೆ (ಕೋಡ್ %d)"

msgid "Confirm Debug Command"
msgstr "ಡೀಬಗ್ ಕಮಾಂಡ್ ಅನ್ನು ದೃಢೀಕರಿಸಿ"

msgid "Debug Log: %s"
msgstr "ಡೀಬಗ್ ಲಾಗ್: %s"

msgid "Delete Log"
msgstr "ಲಾಗ್ ಅಳಿಸಿ"

msgid "Delete/Disable"
msgstr "ಅಳಿಸಿ/ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಿ"

msgid "Deleted: %s"
msgstr "ಅಳಿಸಲಾಗಿದೆ: %s"

msgid "Edit"
msgstr "ಸಂಪಾದಿಸು"

msgid "Edit command"
msgstr "ಆಜ್ಞೆಯನ್ನು ಸಂಪಾದಿಸಿ"

msgid "Edit command (original: %s)"
msgstr "ಆಜ್ಞೆಯನ್ನು ಸಂಪಾದಿಸು (ಮೂಲ: %s)"

msgid "Edit description"
msgstr "ವಿವರಣೆಯನ್ನು ಸಂಪಾದಿಸಿ"

msgid "Enter command"
msgstr "ಆಜ್ಞೆಯನ್ನು ನಮೂದಿಸಿ"

msgid "Enter description"
msgstr "ವಿವರಣೆಯನ್ನು ನಮೂದಿಸಿ"

msgid "Error Only"
msgstr "ದೋಷ ಮಾತ್ರ"

msgid "Error deleting: %s"
msgstr "ಅಳಿಸುವಲ್ಲಿ ದೋಷ: %s"

msgid "Error reading log: %s"
msgstr "ಲಾಗ್ ಓದುವಲ್ಲಿ ದೋಷ: %s"

