msgstr "ಆಜ್ಞೆಯನ್ನು ಪ್ರಾರಂಭಿಸಲು ವಿಫಲವಾಗಿದೆ.\n"

msgid "Full Log"
msgstr "ಪೂರ್ಣ ಲಾಗ್"

msgid "Hide Logs"
msgstr "ದಾಖಲೆಗಳನ್ನು ಮರೆಮಾಡಿ"

msgid "Info"
msgstr "ಮಾಹಿತಿ"

msgid "Log files found: %d | Press Info for show"
msgstr "ಲಾಗ್ ಫೈಲ್‌ಗಳು ಕಂಡುಬಂದಿವೆ: %d | ಪ್ರದರ್ಶನಕ್ಕಾಗಿ ಮಾಹಿತಿ ಒತ್ತಿರಿ"

msgid "Manager"
msgstr "ಮ್ಯಾನೇಜರ್"

msgid "No command selected"
msgstr "ಯಾವುದೇ ಆಜ್ಞೆಯನ್ನು ಆಯ್ಕೆ ಮಾಡಲಾಗಿಲ್ಲ"

msgid "No output to save"
msgstr "ಉಳಿಸಲು ಯಾವುದೇ ಔಟ್‌ಪುಟ್ ಇಲ್ಲ"

msgid "No specific error trace found in log"
msgstr "ಲಾಗ್‌ನಲ್ಲಿ ಯಾವುದೇ ನಿರ್ದಿಷ್ಟ ದೋಷ ಟ್ರೇಸ್ ಕಂಡುಬಂದಿಲ್ಲ"

msgid "Only predefined commands can be disabled/enabled"
msgstr "ಪೂರ್ವನಿರ್ಧರಿತ ಆಜ್ಞೆಗಳನ್ನು ಮಾತ್ರ ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಬಹುದು/ಸಕ್ರಿಯಗೊಳಿಸಬಹುದು"

msgid "Output cleared.\n"
msgstr "ಔಟ್‌ಪುಟ್ ತೆರವುಗೊಳಿಸಲಾಗಿದೆ.\n"

msgid "Press Manager to manage custom commands"
msgstr "ಕಸ್ಟಮ್ ಆಜ್ಞೆಗಳನ್ನು ನಿರ್ವಹಿಸಲು ಮ್ಯಾನೇಜರ್ ಅನ್ನು ಒತ್ತಿರಿ"

msgid "Ready"
msgstr "ಸಿದ್ಧವಾಗಿದೆ"

msgid "Run"
msgstr "ಓಡು"

msgid "Run telnet/shell commands on Enigma2"
msgstr "Enigma2 ನಲ್ಲಿ telnet/shell ಆಜ್ಞೆಗಳನ್ನು ಚಲಾಯಿಸಿ"

msgid "Save"
msgstr "ಉಳಿಸಿ"

msgid "Save error: %s"
msgstr "ದೋಷ ಉಳಿಸು: %s"

msgid "Saved to %s"
msgstr "%s ಗೆ ಉಳಿಸಲಾಗಿದೆ"

msgid "Select a debug command and press Run"
msgstr "ಡೀಬಗ್ ಆಜ್ಞೆಯನ್ನು ಆಯ್ಕೆಮಾಡಿ ಮತ್ತು ರನ್ ಒತ್ತಿರಿ"

msgid "Show Logs"
msgstr "ಲಾಗ್‌ಗಳನ್ನು ತೋರಿಸಿ"

msgid "Toggle Disable"
msgstr "ಟಾಗಲ್ ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಿ"

msgid "Total: %d commands (Predefined: %d, Custom: %d, Disabled: %d)"
msgstr "ಒಟ್ಟು: %d ಆಜ್ಞೆಗಳು (ಪೂರ್ವನಿರ್ಧರಿತ: %d, ಕಸ್ಟಮ್: %d, ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಲಾಗಿದೆ: %d)"
