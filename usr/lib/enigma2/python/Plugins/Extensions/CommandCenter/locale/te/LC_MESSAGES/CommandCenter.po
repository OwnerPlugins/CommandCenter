msgid "Back"
msgstr "వెనుకకు"

msgid "Clear"
msgstr "క్లియర్"

msgid "Close"
msgstr "మూసివేయి"

msgid "Command Center - Telnet/Shell Plugin v.%s - by Lululla."
msgstr "కమాండ్ సెంటర్ - టెల్నెట్/షెల్ ప్లగిన్ v.%s - లులుల్లా ద్వారా."

msgid "Command Center v.%s"
msgstr "కమాండ్ సెంటర్ v.%s"

msgid "Command finished (code %d)"
msgstr "ఆదేశం పూర్తయింది (కోడ్ %d)"

msgid "Confirm Debug Command"
msgstr "డీబగ్ కమాండ్‌ని నిర్ధారించండి"

msgid "Debug Log: %s"
msgstr "డీబగ్ లాగ్: %s"

msgid "Delete Log"
msgstr "లాగ్‌ను తొలగించండి"

msgid "Delete/Disable"
msgstr "తొలగించు/ఆపివేయి"

msgid "Deleted: %s"
msgstr "తొలగించబడింది: %s"

msgid "Edit"
msgstr "సవరించు"

msgid "Edit command"
msgstr "ఆదేశాన్ని సవరించండి"

msgid "Edit command (original: %s)"
msgstr "ఆదేశాన్ని సవరించు (అసలు: %s)"

msgid "Edit description"
msgstr "వివరణను సవరించండి"

msgid "Enter command"
msgstr "ఆదేశాన్ని నమోదు చేయండి"

msgid "Enter description"
msgstr "వివరణను నమోదు చేయండి"

msgid "Error Only"
msgstr "లోపం మాత్రమే"

msgid "Error deleting: %s"
msgstr "తొలగించడంలో లోపం: %s"

msgid "Error reading log: %s"
msgstr "లాగ్ చదవడంలో లోపం: %s"

msgid "Execution error"
msgstr "అమలు లోపం"

msgid "Exit"
msgstr "నిష్క్రమించు"

msgid "Failed to start command.\n"
msgstr "ఆదేశాన్ని ప్రారంభించడంలో విఫలమైంది.\n"

msgid "Full Log"
msgstr "పూర్తి లాగ్"

msgid "Hide Logs"
msgstr "లాగ్‌లను దాచండి"

msgid "Info"
msgstr "సమాచారం"

msgid "Log files found: %d | Press Info for show"
msgstr "లాగ్ ఫైల్‌లు కనుగొనబడ్డాయి: %d | ప్రదర్శన కోసం సమాచారాన్ని నొక్కండి"

msgid "Manager"
msgstr "మేనేజర్"

msgid "No command selected"
msgstr "ఆదేశం ఏదీ ఎంచుకోబడలేదు"

msgid "No output to save"
msgstr "సేవ్ చేయడానికి అవుట్‌పుట్ లేదు"

msgid "No specific error trace found in log"
msgstr "లాగ్‌లో నిర్దిష్ట లోపం ట్రేస్ కనుగొనబడలేదు"

msgid "Only predefined commands can be disabled/enabled"
msgstr "ముందే నిర్వచించబడిన ఆదేశాలు మాత్రమే నిలిపివేయబడతాయి/ప్రారంభించబడతాయి"

msgid "Output cleared.\n"
msgstr "అవుట్‌పుట్ క్లియర్ చేయబడింది.\n"

msgid "Press Manager to manage custom commands"
msgstr "అనుకూల ఆదేశాలను నిర్వహించడానికి మేనేజర్ నొక్కండి"

msgid "Ready"
msgstr "సిద్ధంగా ఉంది"

msgid "Run"
msgstr "పరుగు"

msgid "Run telnet/shell commands on Enigma2"
msgstr "Enigma2పై టెల్నెట్/షెల్ ఆదేశాలను అమలు చేయండి"

msgid "Save"
msgstr "సేవ్ చేయండి"

msgid "Save error: %s"
msgstr "సేవ్ ఎర్రర్: %s"

msgid "Saved to %s"
msgstr "%sకి సేవ్ చేయబడింది"

msgid "Select a debug command and press Run"
msgstr "డీబగ్ ఆదేశాన్ని ఎంచుకుని, రన్ నొక్కండి"

msgid "Show Logs"
msgstr "లాగ్‌లను చూపించు"

msgid "Toggle Disable"
msgstr "టోగుల్ డిసేబుల్"

msgid "Total: %d commands (Predefined: %d, Custom: %d, Disabled: %d)"
msgstr "మొత్తం: %d ఆదేశాలు (ముందే నిర్వచించబడినవి: %d, అనుకూలం: %d, నిలిపివేయబడినవి: %d)"
