msgid "Add Custom"
msgstr "ብጁ ያክሉ"

msgid "Back"
msgstr "ተመለስ"

msgid "Clear"
msgstr "ግልጽ"

msgid "Close"
msgstr "ገጠመ"

msgid "Command Center - Telnet/Shell Plugin v.%s - by Lululla."
msgstr "የትእዛዝ ማእከል - Telnet/Shell Plugin v.%s - በሉሉላ።"

msgid "Command Center v.%s"
msgstr "የትእዛዝ ማዕከል v.%s"

msgid "Command finished (code %d)"
msgstr "ትዕዛዙ አልቋል (ኮድ %d)"

msgid "Confirm Debug Command"
msgstr "የማረም ትዕዛዙን ያረጋግጡ"

msgid "Debug Log: %s"
msgstr "የማረም ምዝግብ ማስታወሻ፡ %s"

msgid "Delete Log"
msgstr "ምዝግብን ሰርዝ"

msgid "Delete/Disable"
msgstr "ሰርዝ/አሰናክል"

msgid "Deleted: %s"
msgstr "ተሰርዟል፡ %s"

msgid "Edit"
msgstr "አርትዕ"

msgid "Edit command"
msgstr "ትዕዛዙን ያርትዑ"

msgid "Edit command (original: %s)"
msgstr "ትዕዛዙን ያርትዑ (የመጀመሪያው: %s)"

msgid "Edit description"
msgstr "መግለጫ አርትዕ"

msgid "Enter command"
msgstr "ትዕዛዝ አስገባ"

msgid "Enter description"
msgstr "መግለጫ አስገባ"

msgid "Error Only"
msgstr "ስህተት ብቻ"

msgid "Error deleting: %s"
msgstr "በመሰረዝ ላይ ስህተት፡ %s"

msgid "Error reading log: %s"
msgstr "የምዝግብ ማስታወሻ ማንበብ ላይ ስህተት: %s"

msgid "Execution error"
msgstr "የማስፈጸም ስህተት"

msgid "Exit"
msgstr "ውጣ"

msgid "Failed to start command.\n"
msgstr "ትእዛዝ መጀመር አልተሳካም።\n"

msgid "Full Log"
msgstr "ሙሉ ምዝግብ ማስታወሻ"

msgid "Hide Logs"
msgstr "ምዝግብ ማስታወሻዎችን ደብቅ"

msgid "Info"
msgstr "መረጃ"

msgid "Log files found: %d | Press Info for show"
msgstr "የምዝግብ ማስታወሻ ፋይሎች ተገኝተዋል፡ %d | ለእይታ መረጃን ይጫኑ"

msgid "Manager"
msgstr "አስተዳዳሪ"

msgid "No command selected"
msgstr "ምንም ትእዛዝ አልተመረጠም።"

msgid "No output to save"
msgstr "ለማስቀመጥ ምንም ውጤት የለም።"

msgid "No specific error trace found in log"
msgstr "በምዝግብ ማስታወሻ ውስጥ ምንም የተለየ የስህተት ዱካ አልተገኘም።"

msgid "Only predefined commands can be disabled/enabled"
msgstr "አስቀድሞ የተገለጹ ትዕዛዞች ብቻ ሊሰናከሉ/ማንቃት ይችላሉ።"

msgid "Output cleared.\n"
msgstr "ውፅዓት ጸድቷል።\n"

msgid "Press Manager to manage custom commands"
msgstr "ብጁ ትዕዛዞችን ለማስተዳደር አስተዳዳሪን ይጫኑ"

msgid "Ready"
msgstr "ዝግጁ"

msgid "Run"
msgstr "ሩጡ"

msgid "Run telnet/shell commands on Enigma2"
msgstr "በEnigma2 ላይ የቴልኔት/ሼል ትዕዛዞችን ያሂዱ"

msgid "Save"
msgstr "አስቀምጥ"

msgid "Save error: %s"
msgstr "ስህተት አስቀምጥ፡ %s"

msgid "Saved to %s"
msgstr "ወደ %s ተቀምጧል"

msgid "Select a debug command and press Run"
msgstr "የማረም ትዕዛዝ ይምረጡ እና አሂድን ይጫኑ"

msgid "Show Logs"
msgstr "የምዝግብ ማስታወሻዎችን አሳይ"

msgid "Toggle Disable"
msgstr "አሰናክልን ቀይር"

msgid "Total: %d commands (Predefined: %d, Custom: %d, Disabled: %d)"
msgstr "ጠቅላላ፡ %d ትዕዛዞች (ቅድመ የተገለጸው፡ %d፣ ብጁ፡ %d፣ ተሰናክሏል፡ %d)"
