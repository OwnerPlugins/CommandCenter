msgstr "Enigma2 এ টেলনেট/শেল কমান্ড চালান"

msgid "Save"
msgstr "সংরক্ষণ করুন"

msgid "Save error: %s"
msgstr "ত্রুটি সংরক্ষণ করুন: %s"

msgid "Saved to %s"
msgstr "%s এ সংরক্ষণ করা হয়েছে"

msgid "Select a debug command and press Run"
msgstr "একটি ডিবাগ কমান্ড নির্বাচন করুন এবং রান টিপুন"

msgid "Show Logs"
msgstr "লগ দেখান"

msgid "Toggle Disable"
msgstr "অক্ষম টগল করুন"

msgid "Total: %d commands (Predefined: %d, Custom: %d, Disabled: %d)"
msgstr "মোট: %d কমান্ড (পূর্বনির্ধারিত: %d, কাস্টম: %d, নিষ্ক্রিয়: %d)"
