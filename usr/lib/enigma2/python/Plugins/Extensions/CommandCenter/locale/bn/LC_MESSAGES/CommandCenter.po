msgstr "ব্যাক"

msgid "Clear"
msgstr "পরিষ্কার"

msgid "Close"
msgstr "বন্ধ"

msgid "Command Center - Telnet/Shell Plugin v.%s - by Lululla."
msgstr "কমান্ড সেন্টার - টেলনেট/শেল প্লাগইন v.%s - লুলুল্লা দ্বারা।"

msgid "Command Center v.%s"
msgstr "কমান্ড সেন্টার v.%s"

msgid "Command finished (code %d)"
msgstr "কমান্ড শেষ হয়েছে (কোড %d)"

msgid "Confirm Debug Command"
msgstr "ডিবাগ কমান্ড নিশ্চিত করুন"

msgid "Debug Log: %s"
msgstr "ডিবাগ লগ: %s"

msgid "Delete Log"
msgstr "লগ মুছুন"

msgid "Delete/Disable"
msgstr "মুছুন/অক্ষম করুন"

msgid "Deleted: %s"
msgstr "মুছে ফেলা হয়েছে: %s"

msgid "Edit"
msgstr "সম্পাদনা করুন"

