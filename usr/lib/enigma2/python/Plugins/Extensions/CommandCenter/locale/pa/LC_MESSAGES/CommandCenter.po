msgid "Add Custom"
msgstr "ਕਸਟਮ ਸ਼ਾਮਲ ਕਰੋ"

msgid "Back"
msgstr "ਵਾਪਸ"

msgid "Clear"
msgstr "ਸਾਫ਼"

msgid "Close"
msgstr "ਬੰਦ ਕਰੋ"

msgid "Command Center - Telnet/Shell Plugin v.%s - by Lululla."
msgstr "ਕਮਾਂਡ ਸੈਂਟਰ - ਟੇਲਨੈੱਟ/ਸ਼ੈਲ ਪਲੱਗਇਨ v.%s - ਲੁਲੁਲਾ ਦੁਆਰਾ।"

msgid "Command Center v.%s"
msgstr "ਕਮਾਂਡ ਸੈਂਟਰ v.%s"

msgid "Command finished (code %d)"
msgstr "ਕਮਾਂਡ ਸਮਾਪਤ (ਕੋਡ %d)"

msgid "Confirm Debug Command"
msgstr "ਡੀਬੱਗ ਕਮਾਂਡ ਦੀ ਪੁਸ਼ਟੀ ਕਰੋ"

msgid "Debug Log: %s"
msgstr "ਡੀਬੱਗ ਲੌਗ: %s"

msgid "Delete Log"
msgstr "ਲੌਗ ਮਿਟਾਓ"

msgid "Delete/Disable"
msgstr "ਮਿਟਾਓ/ਅਯੋਗ ਕਰੋ"

msgid "Deleted: %s"
msgstr "ਮਿਟਾਇਆ ਗਿਆ: %s"

msgid "Edit"
msgstr "ਸੰਪਾਦਿਤ ਕਰੋ"

msgid "Edit command"
msgstr "ਕਮਾਂਡ ਦਾ ਸੰਪਾਦਨ ਕਰੋ"

msgid "Edit command (original: %s)"
msgstr "ਸੰਪਾਦਨ ਕਮਾਂਡ (ਅਸਲ: %s)"

msgid "Edit description"
msgstr "ਵਰਣਨ ਦਾ ਸੰਪਾਦਨ ਕਰੋ"

msgid "Enter command"
msgstr "ਕਮਾਂਡ ਦਿਓ"

msgid "Enter description"
msgstr "ਵੇਰਵਾ ਦਰਜ ਕਰੋ"

msgid "Error Only"
msgstr "ਗਲਤੀ ਸਿਰਫ਼"

msgid "Error deleting: %s"
msgstr "ਮਿਟਾਉਣ ਵਿੱਚ ਤਰੁੱਟੀ: %s"

msgid "Error reading log: %s"
msgstr "ਲੌਗ ਪੜ੍ਹਨ ਵਿੱਚ ਤਰੁੱਟੀ: %s"

msgid "Execution error"
msgstr "ਐਗਜ਼ੀਕਿਊਸ਼ਨ ਗਲਤੀ"

msgid "Exit"
msgstr "ਨਿਕਾਸ"

msgid "Failed to start command.\n"
msgstr "ਕਮਾਂਡ ਸ਼ੁਰੂ ਕਰਨ ਵਿੱਚ ਅਸਫਲ।\n"

msgid "Full Log"
msgstr "ਪੂਰਾ ਲਾਗ"

msgid "Hide Logs"
msgstr "ਲਾਗ ਲੁਕਾਓ"

msgid "Info"
msgstr "ਜਾਣਕਾਰੀ"

msgid "Log files found: %d | Press Info for show"
msgstr "ਲੌਗ ਫਾਈਲਾਂ ਮਿਲੀਆਂ: %d | ਪ੍ਰਦਰਸ਼ਨ ਲਈ ਜਾਣਕਾਰੀ ਦਬਾਓ"

msgid "Manager"
msgstr "ਮੈਨੇਜਰ"

msgid "No command selected"
msgstr "ਕੋਈ ਕਮਾਂਡ ਨਹੀਂ ਚੁਣੀ ਗਈ"

msgid "No output to save"
msgstr "ਬਚਾਉਣ ਲਈ ਕੋਈ ਆਉਟਪੁੱਟ ਨਹੀਂ ਹੈ"

msgid "No specific error trace found in log"
msgstr "ਲਾਗ ਵਿੱਚ ਕੋਈ ਖਾਸ ਗਲਤੀ ਟਰੇਸ ਨਹੀਂ ਮਿਲਿਆ"

msgid "Only predefined commands can be disabled/enabled"
msgstr "ਸਿਰਫ਼ ਪਹਿਲਾਂ ਤੋਂ ਪਰਿਭਾਸ਼ਿਤ ਕਮਾਂਡਾਂ ਨੂੰ ਅਯੋਗ/ਯੋਗ ਕੀਤਾ ਜਾ ਸਕਦਾ ਹੈ"

msgid "Output cleared.\n"
msgstr "ਆਉਟਪੁੱਟ ਸਾਫ਼ ਕੀਤੀ ਗਈ।\n"

msgid "Press Manager to manage custom commands"
msgstr "ਕਸਟਮ ਕਮਾਂਡਾਂ ਦਾ ਪ੍ਰਬੰਧਨ ਕਰਨ ਲਈ ਮੈਨੇਜਰ ਨੂੰ ਦਬਾਓ"

msgid "Ready"
msgstr "ਤਿਆਰ ਹੈ"

msgid "Run"
msgstr "ਚਲਾਓ"

msgid "Run telnet/shell commands on Enigma2"
msgstr "Enigma2 'ਤੇ telnet/shell ਕਮਾਂਡਾਂ ਚਲਾਓ"

msgid "Save"
msgstr "ਸੇਵ ਕਰੋ"

msgid "Save error: %s"
msgstr "ਸੁਰੱਖਿਅਤ ਕਰੋ ਗਲਤੀ: %s"

msgid "Saved to %s"
msgstr "%s ਵਿੱਚ ਸੁਰੱਖਿਅਤ ਕੀਤਾ ਗਿਆ"

msgid "Select a debug command and press Run"
msgstr "ਇੱਕ ਡੀਬੱਗ ਕਮਾਂਡ ਚੁਣੋ ਅਤੇ ਰਨ ਦਬਾਓ"

msgid "Show Logs"
msgstr "ਲੌਗ ਦਿਖਾਓ"

msgid "Toggle Disable"
msgstr "ਟੌਗਲ ਬੰਦ ਕਰੋ"

msgid "Total: %d commands (Predefined: %d, Custom: %d, Disabled: %d)"
msgstr "ਕੁੱਲ: %d ਕਮਾਂਡਾਂ (ਪਹਿਲਾਂ ਤੋਂ ਪਰਿਭਾਸ਼ਿਤ: %d, ਕਸਟਮ: %d, ਅਯੋਗ: %d)"
