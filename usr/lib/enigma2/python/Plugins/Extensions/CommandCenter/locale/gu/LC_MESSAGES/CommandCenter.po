msgstr "સાચવવા માટે કોઈ આઉટપુટ નથી"

msgid "No specific error trace found in log"
msgstr "લોગમાં કોઈ ચોક્કસ ભૂલ ટ્રેસ મળી નથી"

msgid "Only predefined commands can be disabled/enabled"
msgstr "ફક્ત પૂર્વવ્યાખ્યાયિત આદેશોને અક્ષમ/સક્ષમ કરી શકાય છે"

msgid "Output cleared.\n"
msgstr "આઉટપુટ સાફ.\n"

msgid "Press Manager to manage custom commands"
msgstr "કસ્ટમ આદેશોનું સંચાલન કરવા માટે મેનેજર દબાવો"

msgid "Ready"
msgstr "તૈયાર છે"

msgid "Run"
msgstr "ચલાવો"

msgid "Run telnet/shell commands on Enigma2"
msgstr "Enigma2 પર ટેલનેટ/શેલ આદેશો ચલાવો"

msgid "Save"
msgstr "સાચવો"

msgid "Save error: %s"
msgstr "ભૂલ સાચવો: %s"

msgid "Saved to %s"
msgstr "%s માં સાચવેલ"

msgid "Select a debug command and press Run"
msgstr "ડીબગ આદેશ પસંદ કરો અને રન દબાવો"

msgid "Show Logs"
msgstr "લૉગ્સ બતાવો"

msgid "Toggle Disable"
msgstr "ટૉગલ અક્ષમ કરો"

msgid "Total: %d commands (Predefined: %d, Custom: %d, Disabled: %d)"
msgstr "કુલ: %d આદેશો (પૂર્વવ્યાખ્યાયિત: %d, કસ્ટમ: %d, અક્ષમ: %d)"
