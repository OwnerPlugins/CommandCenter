msgstr "સાફ કરો"

msgid "Close"
msgstr "બંધ કરો"

msgid "Command Center - Telnet/Shell Plugin v.%s - by Lululla."
msgstr "કમાન્ડ સેન્ટર - ટેલનેટ/શેલ પ્લગઇન v.%s - લુલુલા દ્વારા."

msgid "Command Center v.%s"
msgstr "કમાન્ડ સેન્ટર v.%s"

msgid "Command finished (code %d)"
msgstr "આદેશ સમાપ્ત થયો (કોડ %d)"

msgid "Confirm Debug Command"
msgstr "ડીબગ આદેશની પુષ્ટિ કરો"

msgid "Debug Log: %s"
msgstr "ડીબગ લોગ: %s"

msgid "Delete Log"
msgstr "લોગ કાઢી નાખો"

msgid "Delete/Disable"
msgstr "કાઢી નાખો/અક્ષમ કરો"

msgid "Deleted: %s"
msgstr "કાઢી નાખ્યું: %s"

msgid "Edit"
msgstr "સંપાદિત કરો"

